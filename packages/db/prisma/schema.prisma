// Phase 1 — Lead scraping ✅
// Phase 2 — CRM core: lead detail, groups (manual + smart), notes ✅
// Future: contacts (multi per lead), activities, campaigns, workflows, tenants/users.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScrapeJobStatus {
  queued
  running
  done
  failed
  cancelled
}

enum GroupType {
  manual
  smart
}

enum EmailStatus {
  queued
  sending
  sent
  failed
}

model ScrapeJob {
  id             String          @id @default(uuid())
  source         String          @default("yellowpages")
  searchQuery    String          @map("search_query")
  searchLocation String          @map("search_location")
  status         ScrapeJobStatus @default(queued)
  totalFound     Int             @default(0) @map("total_found")
  totalSaved     Int             @default(0) @map("total_saved")
  error          String?
  startedAt      DateTime?       @map("started_at")
  finishedAt    DateTime?       @map("finished_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  leads Lead[]

  @@index([status])
  @@index([searchQuery, searchLocation])
  @@map("scrape_jobs")
}

model Lead {
  id             String   @id @default(uuid())
  jobId          String?  @map("job_id")

  // Source provenance
  source         String   @default("yellowpages")
  sourceUrl      String?  @map("source_url")
  externalId     String?  @map("external_id")

  // Search context (denormalized for fast filtering / autocomplete)
  searchQuery    String   @map("search_query")
  searchLocation String   @map("search_location")

  // Core business fields
  businessName   String   @map("business_name")
  category       String?           // primary category
  categories     String[]          @default([])  // all categories listed
  phone          String?
  phones         String[]          @default([])  // additional phones
  fax            String?
  email          String?
  emails         String[]          @default([])  // all harvested emails
  website        String?

  // Address
  address        String?
  address2       String?
  city           String?
  state          String?
  postalCode     String?  @map("postal_code")
  country        String?  @default("US")
  latitude       Float?
  longitude      Float?

  // Business profile (slim — kept only what we use in CRM lead lists)
  description    String?  @db.Text   // "General Info" paragraph from YP
  businessHistory String? @db.Text  @map("business_history")
  yearEstablished Int?    @map("year_established")
  neighborhoods  String[] @default([])
  rating         Float?
  reviewCount    Int?     @map("review_count")
  bbbGrade       String?  @map("bbb_grade")
  yearsInBusiness Int?    @map("years_in_business")
  yearsWithYP    Int?     @map("years_with_yp")
  claimed        Boolean  @default(false)
  photos         String[] @default([])
  logoUrl        String?  @map("logo_url")
  bannerUrl      String?  @map("banner_url")
  otherLinks     String[] @default([]) @map("other_links")  // additional websites

  // All unique social URLs found across YP listing + business website.
  // Frontend classifies platform from the URL host at render time.
  socials        String[] @default([])

  // Owner enrichment (best-effort)
  ownerName      String?  @map("owner_name")
  ownerEmail     String?  @map("owner_email")
  ownerPhone     String?  @map("owner_phone")
  ownerLinkedin  String?  @map("owner_linkedin")
  ownerSearchUrl String?  @map("owner_search_url")  // pre-built Google query for owner discovery

  // Dedup hash: sha1(lower(business_name) + normalize(phone) + normalize(address))
  dedupHash      String?  @map("dedup_hash")

  // Original parsed payload for debugging / re-processing
  rawPayload     Json?    @map("raw_payload")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  job              ScrapeJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  groupMemberships LeadGroupMember[]
  notes            Note[]
  emailLogs        EmailLog[]

  @@unique([source, dedupHash])
  @@index([searchQuery, searchLocation])
  @@index([city, state])
  @@index([website])
  @@index([createdAt])
  @@index([rating])
  @@index([yearsInBusiness])
  @@map("leads")
}

model LeadGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        GroupType
  filterDsl   Json?     @map("filter_dsl")  // for smart groups: same shape as /leads query params
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  members LeadGroupMember[]

  @@index([type])
  @@index([createdAt])
  @@map("lead_groups")
}

model LeadGroupMember {
  groupId String   @map("group_id")
  leadId  String   @map("lead_id")
  addedAt DateTime @default(now()) @map("added_at")

  group LeadGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  lead  Lead      @relation(fields: [leadId],  references: [id], onDelete: Cascade)

  @@id([groupId, leadId])
  @@index([leadId])
  @@map("lead_group_members")
}

model Note {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  body      String   @db.Text
  authorId  String?  @map("author_id")           // hooks into users table later
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("notes")
}

// ─── Email sending (Phase 3, MVP) ─────────────────────────────────────────
//
// EmailAccount holds OAuth credentials for an outbox the user has connected
// (currently only Gmail). Refresh tokens are encrypted at rest using
// EMAIL_TOKEN_ENC_KEY (AES-256-GCM, see apps/api/.../crypto.ts).

model EmailAccount {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String?  @map("display_name")
  provider     String   @default("gmail")     // gmail|outlook|smtp
  accessToken  String   @db.Text @map("access_token")
  refreshToken String   @db.Text @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  scopes       String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  emailLogs EmailLog[]

  @@index([active])
  @@map("email_accounts")
}

// EmailLog is one record per send attempt. Reply / open / click / bounce
// columns are present but unused in MVP — they hook into pixel + IMAP
// listeners we'll add in Phase 4.

model EmailLog {
  id        String      @id @default(uuid())
  leadId    String      @map("lead_id")
  accountId String?     @map("account_id")

  fromEmail String      @map("from_email")
  fromName  String?     @map("from_name")
  toEmail   String      @map("to_email")
  cc        String[]    @default([])
  bcc       String[]    @default([])
  subject   String
  bodyHtml  String?     @db.Text @map("body_html")
  bodyText  String?     @db.Text @map("body_text")

  status    EmailStatus @default(queued)
  provider  String      @default("gmail")
  messageId String?     @map("message_id")    // Gmail message id (Message-ID header)
  threadId  String?     @map("thread_id")     // Gmail threadId — for reply detection

  // Tracking key embedded in pixel + click links. Unique so we can look up by it.
  trackingId String     @unique @default(uuid()) @map("tracking_id")

  error     String?     @db.Text

  // Phase 4 hooks (nullable for now)
  openedAt       DateTime? @map("opened_at")
  firstClickedAt DateTime? @map("first_clicked_at")
  repliedAt      DateTime? @map("replied_at")
  bouncedAt      DateTime? @map("bounced_at")

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  lead    Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  account EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([status])
  @@index([threadId])
  @@map("email_logs")
}
