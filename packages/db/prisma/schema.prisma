// Phase 1 — Lead scraping ✅
// Phase 2 — CRM core: lead detail, groups (manual + smart), notes ✅
// Future: contacts (multi per lead), activities, campaigns, workflows, tenants/users.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScrapeJobStatus {
  queued
  running
  done
  failed
  cancelled
}

enum GroupType {
  manual
  smart
}

enum EmailStatus {
  queued
  sending
  sent
  failed
}

// ─── Phase 5: Contacts + Lead pipeline state ─────────────────────────────

enum ContactType {
  owner
  manager
  staff
  general
}

enum ContactSource {
  manual
  website
  directory
  enrichment
}

enum Confidence {
  low
  medium
  high
}

enum ContactStatus {
  unverified
  verified
  invalid
}

enum LeadStage {
  new
  approached
  no_response
  engaged
  push
  qualified
  interested
  booked
  proposal_sent
  converted
  not_converted
  lost
}

enum LeadValidity {
  valid
  invalid
}

enum FollowUpStatus {
  none
  needed
  scheduled
  completed
  overdue
}

// ─── Phase 6: Tasks / Follow-ups ──────────────────────────────────────────

enum TaskStatus {
  open
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskKind {
  general
  followup
}

enum TaskContext {
  none
  approached_followup
  engaged_followup
  qualified_followup
  meeting_followup
  proposal_followup
  no_response_followup
  push_followup
  interested_followup
}

model ScrapeJob {
  id             String          @id @default(uuid())
  source         String          @default("yellowpages")
  searchQuery    String          @map("search_query")
  searchLocation String          @map("search_location")
  status         ScrapeJobStatus @default(queued)
  totalFound     Int             @default(0) @map("total_found")
  totalSaved     Int             @default(0) @map("total_saved")
  error          String?
  startedAt      DateTime?       @map("started_at")
  finishedAt    DateTime?       @map("finished_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  leads Lead[]

  @@index([status])
  @@index([searchQuery, searchLocation])
  @@map("scrape_jobs")
}

model Lead {
  id             String   @id @default(uuid())
  jobId          String?  @map("job_id")

  // Source provenance
  source         String   @default("yellowpages")
  sourceUrl      String?  @map("source_url")
  externalId     String?  @map("external_id")

  // Search context (denormalized for fast filtering / autocomplete)
  searchQuery    String   @map("search_query")
  searchLocation String   @map("search_location")

  // Core business fields
  businessName   String   @map("business_name")
  category       String?           // primary category
  categories     String[]          @default([])  // all categories listed
  phone          String?
  phones         String[]          @default([])  // additional phones
  fax            String?
  email          String?
  emails         String[]          @default([])  // all harvested emails
  website        String?

  // Address
  address        String?
  address2       String?
  city           String?
  state          String?
  postalCode     String?  @map("postal_code")
  country        String?  @default("US")
  latitude       Float?
  longitude      Float?

  // Business profile (slim — kept only what we use in CRM lead lists)
  description    String?  @db.Text   // "General Info" paragraph from YP
  businessHistory String? @db.Text  @map("business_history")
  yearEstablished Int?    @map("year_established")
  neighborhoods  String[] @default([])
  rating         Float?
  reviewCount    Int?     @map("review_count")
  bbbGrade       String?  @map("bbb_grade")
  yearsInBusiness Int?    @map("years_in_business")
  yearsWithYP    Int?     @map("years_with_yp")
  claimed        Boolean  @default(false)
  photos         String[] @default([])
  logoUrl        String?  @map("logo_url")
  bannerUrl      String?  @map("banner_url")
  otherLinks     String[] @default([]) @map("other_links")  // additional websites

  // All unique social URLs found across YP listing + business website.
  // Frontend classifies platform from the URL host at render time.
  socials        String[] @default([])

  // Owner enrichment (best-effort) — legacy; the scraper still writes here
  // and the lead detail still surfaces it. Phase 5 introduces the
  // structured `contacts` table; these stay until every reader migrates.
  ownerName      String?  @map("owner_name")
  ownerEmail     String?  @map("owner_email")
  ownerPhone     String?  @map("owner_phone")
  ownerLinkedin  String?  @map("owner_linkedin")
  ownerSearchUrl String?  @map("owner_search_url")  // pre-built Google query for owner discovery

  // Phase 5 — pipeline state. Defaults make every existing row a sensible
  // "new / valid / score=0" record without backfill.
  stage          LeadStage      @default(new)
  score          Int            @default(0)
  validity       LeadValidity   @default(valid)
  followUpStatus FollowUpStatus @default(none) @map("follow_up_status")

  // Phase 7 — last time `stage` actually changed. Used by automation rules
  // that need "X has been in stage Y for N days" precision; lead.updatedAt
  // is too noisy because it bumps on every column write.
  stageChangedAt DateTime?      @map("stage_changed_at")

  // Dedup hash: sha1(lower(business_name) + normalize(phone) + normalize(address))
  dedupHash      String?  @map("dedup_hash")

  // Original parsed payload for debugging / re-processing
  rawPayload     Json?    @map("raw_payload")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  job              ScrapeJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  groupMemberships LeadGroupMember[]
  notes            Note[]
  emailLogs        EmailLog[]
  contacts         Contact[]
  tasks            Task[]
  campaignRecipients CampaignRecipient[]

  @@unique([source, dedupHash])
  @@index([searchQuery, searchLocation])
  @@index([city, state])
  @@index([website])
  @@index([createdAt])
  @@index([rating])
  @@index([yearsInBusiness])
  @@index([stage])
  @@index([validity])
  @@map("leads")
}

// ─── Phase 5: Contacts ───────────────────────────────────────────────────
//
// Multiple structured contacts per lead. The legacy `owner_*` columns on
// leads are migrated into a single primary `owner`-type contact at
// migration time (see migration SQL) and stay populated by the scraper
// until a later phase removes them.

model Contact {
  id            String        @id @default(uuid())
  leadId        String        @map("lead_id")
  name          String
  contactType   ContactType   @default(general)    @map("contact_type")
  email         String?
  phone         String?
  linkedin      String?
  socialProfile String?       @map("social_profile")
  source        ContactSource @default(manual)
  confidence    Confidence    @default(low)
  status        ContactStatus @default(unverified)
  isPrimary     Boolean       @default(false)      @map("is_primary")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())      @map("created_at")
  updatedAt     DateTime      @updatedAt           @map("updated_at")

  lead  Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tasks Task[]
  campaignRecipients CampaignRecipient[]

  @@index([leadId])
  @@index([leadId, isPrimary])
  @@map("contacts")
}

/// One row per actionable task or follow-up. Phase 6 only supports manual
/// creation; the rule engine that auto-creates follow-ups on email events
/// arrives in a later phase.
model Task {
  id              String       @id @default(uuid())
  leadId          String       @map("lead_id")
  contactId       String?      @map("contact_id")
  title           String
  description     String?      @db.Text
  status          TaskStatus   @default(open)
  priority        TaskPriority @default(medium)
  kind            TaskKind     @default(general)
  context         TaskContext  @default(none)
  dueAt           DateTime?    @map("due_at")
  completedAt     DateTime?    @map("completed_at")
  /// Stage the lead was in when this task was created — useful for context filters.
  stageAtCreation LeadStage    @map("stage_at_creation")
  /// Free-form attribution string until multi-tenant arrives. Phase 7 swaps this for a user FK.
  assignedTo      String?      @map("assigned_to")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt      @map("updated_at")

  lead    Lead     @relation(fields: [leadId],    references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status, dueAt])
  @@index([dueAt])
  @@index([kind, context])
  @@map("tasks")
}

model LeadGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        GroupType
  filterDsl   Json?     @map("filter_dsl")  // for smart groups: same shape as /leads query params
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  members   LeadGroupMember[]
  campaigns Campaign[]

  @@index([type])
  @@index([createdAt])
  @@map("lead_groups")
}

model LeadGroupMember {
  groupId String   @map("group_id")
  leadId  String   @map("lead_id")
  addedAt DateTime @default(now()) @map("added_at")

  group LeadGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  lead  Lead      @relation(fields: [leadId],  references: [id], onDelete: Cascade)

  @@id([groupId, leadId])
  @@index([leadId])
  @@map("lead_group_members")
}

model Note {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  body      String   @db.Text
  authorId  String?  @map("author_id")           // hooks into users table later
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("notes")
}

// ─── Email sending (Phase 3, MVP) ─────────────────────────────────────────
//
// EmailAccount holds OAuth credentials for an outbox the user has connected
// (currently only Gmail). Refresh tokens are encrypted at rest using
// EMAIL_TOKEN_ENC_KEY (AES-256-GCM, see apps/api/.../crypto.ts).

model EmailAccount {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String?  @map("display_name")
  provider     String   @default("gmail")     // gmail|outlook|smtp
  accessToken  String   @db.Text @map("access_token")
  refreshToken String   @db.Text @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  scopes       String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  emailLogs EmailLog[]
  campaigns Campaign[]

  @@index([active])
  @@map("email_accounts")
}

// EmailLog is one record per send attempt. Reply / open / click / bounce
// columns are present but unused in MVP — they hook into pixel + IMAP
// listeners we'll add in Phase 4.

model EmailLog {
  id        String      @id @default(uuid())
  leadId    String      @map("lead_id")
  accountId String?     @map("account_id")

  fromEmail String      @map("from_email")
  fromName  String?     @map("from_name")
  toEmail   String      @map("to_email")
  cc        String[]    @default([])
  bcc       String[]    @default([])
  subject   String
  bodyHtml  String?     @db.Text @map("body_html")
  bodyText  String?     @db.Text @map("body_text")

  status      EmailStatus @default(queued)
  provider    String      @default("gmail")
  messageId   String?     @map("message_id")    // Gmail message id (Message-ID header)
  threadId    String?     @map("thread_id")     // Gmail threadId — for reply detection

  // [{filename, mimeType, size, storagePath}, ...]
  attachments Json        @default("[]")

  // Tracking key embedded in pixel + click links. Unique so we can look up by it.
  trackingId String     @unique @default(uuid()) @map("tracking_id")

  error     String?     @db.Text

  // Phase 4 hooks (nullable for now)
  openedAt       DateTime? @map("opened_at")
  firstClickedAt DateTime? @map("first_clicked_at")
  repliedAt      DateTime? @map("replied_at")
  bouncedAt      DateTime? @map("bounced_at")

  // Phase 9 — set when this log was generated by a campaign tick rather
  // than a single one-off send.
  campaignId String? @map("campaign_id")

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  lead     Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  account  EmailAccount?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  campaign Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  replies  EmailReply[]
  campaignRecipient CampaignRecipient?

  @@index([leadId, createdAt])
  @@index([status])
  @@index([threadId])
  @@index([campaignId])
  @@map("email_logs")
}

/// One row per tracking-pixel fetch. Lets us inspect *who* is opening the
/// email (Gmail's image proxy, the recipient's actual browser, etc.) and
/// defend against pre-fetch false positives.
model EmailPixelHit {
  id          String   @id @default(uuid())
  emailLogId  String   @map("email_log_id")
  trackingId  String   @map("tracking_id")
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address")
  /// Set true if this hit landed within the prefetch window (likely Gmail
  /// proxy pre-fetching on delivery, not a real open).
  suspectedPrefetch Boolean  @default(false) @map("suspected_prefetch")
  hitAt       DateTime @default(now()) @map("hit_at")

  @@index([emailLogId, hitAt])
  @@index([trackingId])
  @@map("email_pixel_hits")
}

/// Inbound replies fetched from Gmail by polling the thread of a sent email.
/// The first time we see a new message in a thread we own, we insert a row
/// here and bump email_logs.repliedAt.
model EmailReply {
  id              String   @id @default(uuid())
  emailLogId      String   @map("email_log_id")
  leadId          String   @map("lead_id")

  gmailMessageId  String   @unique @map("gmail_message_id")
  threadId        String   @map("thread_id")
  fromEmail       String   @map("from_email")
  fromName        String?  @map("from_name")
  toEmail         String?  @map("to_email")
  subject         String?
  snippet         String?  @db.Text             // short preview from Gmail
  bodyText        String?  @db.Text @map("body_text")
  bodyHtml        String?  @db.Text @map("body_html")

  receivedAt      DateTime @map("received_at")
  createdAt       DateTime @default(now()) @map("created_at")

  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([emailLogId])
  @@index([leadId])
  @@map("email_replies")
}

// ─── Phase 9: Email templates + campaigns ────────────────────────────────

enum CampaignStatus {
  draft
  queued
  running
  paused
  completed
  failed
  cancelled
}

enum CampaignRecipientStatus {
  pending
  sending
  sent
  failed
  skipped
  bounced
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  subject     String
  bodyText    String   @db.Text @map("body_text")
  /// Optional. If null we render bodyText as HTML at send time.
  bodyHtml    String?  @db.Text @map("body_html")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  campaigns Campaign[]

  @@index([createdAt])
  @@map("email_templates")
}

model Campaign {
  id              String         @id @default(uuid())
  name            String
  description     String?
  status          CampaignStatus @default(draft)

  groupId         String         @map("group_id")
  templateId      String         @map("template_id")
  accountId       String         @map("account_id")

  /// Frozen subject + bodies copied from the template at start time.
  /// Editing the template after a campaign starts MUST NOT retroactively
  /// change what recipients see.
  frozenSubject  String?  @map("frozen_subject")
  frozenBodyText String?  @db.Text @map("frozen_body_text")
  frozenBodyHtml String?  @db.Text @map("frozen_body_html")

  /// Per-account daily cap honored at queue-pick time. Default 250
  /// (half of Gmail free-tier 500/day).
  dailySendLimit  Int @default(250) @map("daily_send_limit")
  /// Inter-send delay in seconds. Default 12 (~5/min, gentle on Gmail).
  sendIntervalSec Int @default(12)  @map("send_interval_sec")

  recipientCount Int @default(0) @map("recipient_count")
  sentCount      Int @default(0) @map("sent_count")
  failedCount    Int @default(0) @map("failed_count")
  skippedCount   Int @default(0) @map("skipped_count")

  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt      @map("updated_at")

  group      LeadGroup           @relation(fields: [groupId],    references: [id], onDelete: Restrict)
  template   EmailTemplate       @relation(fields: [templateId], references: [id], onDelete: Restrict)
  account    EmailAccount        @relation(fields: [accountId],  references: [id], onDelete: Restrict)
  recipients CampaignRecipient[]
  emailLogs  EmailLog[]

  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String                  @id @default(uuid())
  campaignId String                  @map("campaign_id")
  leadId     String                  @map("lead_id")
  contactId  String?                 @map("contact_id")
  toEmail    String                  @map("to_email")

  renderedSubject  String?  @map("rendered_subject")
  renderedBodyText String?  @db.Text @map("rendered_body_text")
  renderedBodyHtml String?  @db.Text @map("rendered_body_html")

  status      CampaignRecipientStatus @default(pending)
  emailLogId  String?                 @unique @map("email_log_id")
  error       String?                 @db.Text
  attemptedAt DateTime?               @map("attempted_at")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead      @relation(fields: [leadId],     references: [id], onDelete: Cascade)
  contact  Contact?  @relation(fields: [contactId],  references: [id], onDelete: SetNull)
  emailLog EmailLog? @relation(fields: [emailLogId], references: [id], onDelete: SetNull)

  @@unique([campaignId, leadId])
  @@index([campaignId, status])
  @@map("campaign_recipients")
}
