// Phase 1 — Lead scraping ✅
// Phase 2 — CRM core: lead detail, groups (manual + smart), notes ✅
// Future: contacts (multi per lead), activities, campaigns, workflows, tenants/users.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScrapeJobStatus {
  queued
  running
  done
  failed
  cancelled
}

enum GroupType {
  manual
  smart
}

enum EmailStatus {
  queued
  sending
  sent
  failed
}

// ─── Phase 5: Contacts + Lead pipeline state ─────────────────────────────

enum ContactType {
  owner
  manager
  staff
  general
}

enum ContactSource {
  manual
  website
  directory
  enrichment
}

enum Confidence {
  low
  medium
  high
}

enum ContactStatus {
  unverified
  verified
  invalid
}

enum LeadStage {
  new
  approached
  no_response
  engaged
  push
  qualified
  interested
  booked
  proposal_sent
  converted
  not_converted
  lost
}

enum LeadValidity {
  valid
  invalid
}

enum FollowUpStatus {
  none
  needed
  scheduled
  completed
  overdue
}

// ─── Phase 6: Tasks / Follow-ups ──────────────────────────────────────────

enum TaskStatus {
  open
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskKind {
  general
  followup
}

enum TaskContext {
  none
  approached_followup
  engaged_followup
  qualified_followup
  meeting_followup
  proposal_followup
  no_response_followup
  push_followup
  interested_followup
}

// ─── Phase 10: Meetings ───────────────────────────────────────────────────

enum MeetingType {
  phone
  zoom
  google_meet
  in_person
  other
}

enum MeetingStatus {
  scheduled
  completed
  cancelled
  no_show
}

// ─── Phase 11: Proposals ──────────────────────────────────────────────────

enum ProposalStatus {
  draft
  sent
  failed
}

// ─── Phase 12: Calls ──────────────────────────────────────────────────────

enum CallDirection {
  outbound
  inbound
}

enum CallOutcome {
  answered
  no_answer
  voicemail
  busy
  wrong_number
  do_not_call
  scheduled_callback
}

enum CallStatus {
  scheduled
  completed
  cancelled
}

model ScrapeJob {
  id             String          @id @default(uuid())
  source         String          @default("yellowpages")
  searchQuery    String          @map("search_query")
  searchLocation String          @map("search_location")
  status         ScrapeJobStatus @default(queued)
  totalFound     Int             @default(0) @map("total_found")
  totalSaved     Int             @default(0) @map("total_saved")
  error          String?
  startedAt      DateTime?       @map("started_at")
  finishedAt     DateTime?       @map("finished_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  leads Lead[]

  @@index([status])
  @@index([searchQuery, searchLocation])
  @@map("scrape_jobs")
}

model Lead {
  id    String  @id @default(uuid())
  jobId String? @map("job_id")

  // Source provenance
  source     String  @default("yellowpages")
  sourceUrl  String? @map("source_url")
  externalId String? @map("external_id")

  // Search context (denormalized for fast filtering / autocomplete)
  searchQuery    String @map("search_query")
  searchLocation String @map("search_location")

  // Core business fields
  businessName String   @map("business_name")
  category     String? // primary category
  categories   String[] @default([]) // all categories listed
  phone        String?
  phones       String[] @default([]) // additional phones
  fax          String?
  email        String?
  emails       String[] @default([]) // all harvested emails
  website      String?

  // Address
  address    String?
  address2   String?
  city       String?
  state      String?
  postalCode String? @map("postal_code")
  country    String? @default("US")
  latitude   Float?
  longitude  Float?

  // Business profile (slim — kept only what we use in CRM lead lists)
  description     String?  @db.Text // "General Info" paragraph from YP
  businessHistory String?  @map("business_history") @db.Text
  yearEstablished Int?     @map("year_established")
  neighborhoods   String[] @default([])
  rating          Float?
  reviewCount     Int?     @map("review_count")
  bbbGrade        String?  @map("bbb_grade")
  yearsInBusiness Int?     @map("years_in_business")
  yearsWithYP     Int?     @map("years_with_yp")
  claimed         Boolean  @default(false)
  photos          String[] @default([])
  logoUrl         String?  @map("logo_url")
  bannerUrl       String?  @map("banner_url")
  otherLinks      String[] @default([]) @map("other_links") // additional websites

  // All unique social URLs found across YP listing + business website.
  // Frontend classifies platform from the URL host at render time.
  socials String[] @default([])

  // Owner enrichment (best-effort) — legacy; the scraper still writes here
  // and the lead detail still surfaces it. Phase 5 introduces the
  // structured `contacts` table; these stay until every reader migrates.
  ownerName      String? @map("owner_name")
  ownerEmail     String? @map("owner_email")
  ownerPhone     String? @map("owner_phone")
  ownerLinkedin  String? @map("owner_linkedin")
  ownerSearchUrl String? @map("owner_search_url") // pre-built Google query for owner discovery

  // Phase 5 — pipeline state. Defaults make every existing row a sensible
  // "new / valid / score=0" record without backfill.
  stage          LeadStage      @default(new)
  score          Int            @default(0)
  validity       LeadValidity   @default(valid)
  followUpStatus FollowUpStatus @default(none) @map("follow_up_status")

  // Phase 7 — last time `stage` actually changed. Used by automation rules
  // that need "X has been in stage Y for N days" precision; lead.updatedAt
  // is too noisy because it bumps on every column write.
  stageChangedAt DateTime? @map("stage_changed_at")

  // Dedup hash: sha1(lower(business_name) + normalize(phone) + normalize(address))
  dedupHash String? @map("dedup_hash")

  // Original parsed payload for debugging / re-processing
  rawPayload Json? @map("raw_payload")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job                 ScrapeJob?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  groupMemberships    LeadGroupMember[]
  notes               Note[]
  emailLogs           EmailLog[]
  contacts            Contact[]
  tasks               Task[]
  meetings            Meeting[]
  proposals           Proposal[]
  calls               Call[]
  campaignRecipients  CampaignRecipient[]
  sequenceEnrollments SequenceEnrollment[]
  stageHistory        LeadStageHistory[]

  @@unique([source, dedupHash])
  @@index([searchQuery, searchLocation])
  @@index([city, state])
  @@index([website])
  @@index([createdAt])
  @@index([rating])
  @@index([yearsInBusiness])
  @@index([stage])
  @@index([validity])
  @@map("leads")
}

// ─── Phase 5: Contacts ───────────────────────────────────────────────────
//
// Multiple structured contacts per lead. The legacy `owner_*` columns on
// leads are migrated into a single primary `owner`-type contact at
// migration time (see migration SQL) and stay populated by the scraper
// until a later phase removes them.

model Contact {
  id            String        @id @default(uuid())
  leadId        String        @map("lead_id")
  name          String
  contactType   ContactType   @default(general) @map("contact_type")
  email         String?
  phone         String?
  linkedin      String?
  socialProfile String?       @map("social_profile")
  source        ContactSource @default(manual)
  confidence    Confidence    @default(low)
  status        ContactStatus @default(unverified)
  isPrimary     Boolean       @default(false) @map("is_primary")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  lead                Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tasks               Task[]
  meetings            Meeting[]
  proposals           Proposal[]
  calls               Call[]
  campaignRecipients  CampaignRecipient[]
  sequenceEnrollments SequenceEnrollment[]

  @@index([leadId])
  @@index([leadId, isPrimary])
  @@map("contacts")
}

/// One row per actionable task or follow-up. Phase 6 only supports manual
/// creation; the rule engine that auto-creates follow-ups on email events
/// arrives in a later phase.
model Task {
  id              String       @id @default(uuid())
  leadId          String       @map("lead_id")
  contactId       String?      @map("contact_id")
  title           String
  description     String?      @db.Text
  status          TaskStatus   @default(open)
  priority        TaskPriority @default(medium)
  kind            TaskKind     @default(general)
  context         TaskContext  @default(none)
  dueAt           DateTime?    @map("due_at")
  completedAt     DateTime?    @map("completed_at")
  /// Stage the lead was in when this task was created — useful for context filters.
  stageAtCreation LeadStage    @map("stage_at_creation")
  /// Legacy free-form attribution. Kept for backfill; new writes should use assigneeId.
  assignedTo      String?      @map("assigned_to")
  /// FK to WorkspaceMember — the employee this task belongs to.
  assigneeId      String?      @map("assignee_id")
  /// FK to WorkspaceMember — who created the task.
  createdById     String?      @map("created_by_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact   Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee  WorkspaceMember? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy WorkspaceMember? @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status, dueAt])
  @@index([dueAt])
  @@index([kind, context])
  @@index([assigneeId, status])
  @@index([assigneeId, dueAt])
  @@map("tasks")
}

model LeadGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        GroupType
  filterDsl   Json?     @map("filter_dsl") // for smart groups: same shape as /leads query params
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members   LeadGroupMember[]
  campaigns Campaign[]
  sequences Sequence[]

  @@index([type])
  @@index([createdAt])
  @@map("lead_groups")
}

model LeadGroupMember {
  groupId String   @map("group_id")
  leadId  String   @map("lead_id")
  addedAt DateTime @default(now()) @map("added_at")

  group LeadGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  lead  Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([groupId, leadId])
  @@index([leadId])
  @@map("lead_group_members")
}

model Note {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  body      String   @db.Text
  authorId  String?  @map("author_id") // hooks into users table later
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("notes")
}

// ─── Email sending (Phase 3, MVP) ─────────────────────────────────────────
//
// EmailAccount holds OAuth credentials for an outbox the user has connected
// (currently only Gmail). Refresh tokens are encrypted at rest using
// EMAIL_TOKEN_ENC_KEY (AES-256-GCM, see apps/api/.../crypto.ts).

model EmailAccount {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String?  @map("display_name")
  provider     String   @default("gmail") // gmail|outlook|smtp
  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at")
  scopes       String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  emailLogs EmailLog[]
  campaigns Campaign[]
  meetings  Meeting[]
  proposals Proposal[]
  sequences Sequence[]

  @@index([active])
  @@map("email_accounts")
}

// EmailLog is one record per send attempt. Reply / open / click / bounce
// columns are present but unused in MVP — they hook into pixel + IMAP
// listeners we'll add in Phase 4.

model EmailLog {
  id        String  @id @default(uuid())
  leadId    String  @map("lead_id")
  accountId String? @map("account_id")

  fromEmail String   @map("from_email")
  fromName  String?  @map("from_name")
  toEmail   String   @map("to_email")
  cc        String[] @default([])
  bcc       String[] @default([])
  subject   String
  bodyHtml  String?  @map("body_html") @db.Text
  bodyText  String?  @map("body_text") @db.Text

  status    EmailStatus @default(queued)
  provider  String      @default("gmail")
  messageId String?     @map("message_id") // Gmail message id (Message-ID header)
  threadId  String?     @map("thread_id") // Gmail threadId — for reply detection

  // [{filename, mimeType, size, storagePath}, ...]
  attachments Json @default("[]")

  // Tracking key embedded in pixel + click links. Unique so we can look up by it.
  trackingId String @unique @default(uuid()) @map("tracking_id")

  error String? @db.Text

  // Phase 4 hooks (nullable for now)
  openedAt       DateTime? @map("opened_at")
  firstClickedAt DateTime? @map("first_clicked_at")
  repliedAt      DateTime? @map("replied_at")
  bouncedAt      DateTime? @map("bounced_at")

  // Phase 9 — set when this log was generated by a campaign tick rather
  // than a single one-off send.
  campaignId String? @map("campaign_id")

  // Phase 18 — set when this log was generated by a sequence step send.
  sequenceEnrollmentSendId String? @unique @map("sequence_enrollment_send_id")

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  lead                   Lead                    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  account                EmailAccount?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  campaign               Campaign?               @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  replies                EmailReply[]
  campaignRecipient      CampaignRecipient?
  proposal               Proposal?               @relation("ProposalEmailLog")
  sequenceEnrollmentSend SequenceEnrollmentSend? @relation("SequenceEnrollmentSendEmailLog")

  @@index([leadId, createdAt])
  @@index([status])
  @@index([threadId])
  @@index([campaignId])
  @@map("email_logs")
}

/// One row per tracking-pixel fetch. Lets us inspect *who* is opening the
/// email (Gmail's image proxy, the recipient's actual browser, etc.) and
/// defend against pre-fetch false positives.
model EmailPixelHit {
  id                String   @id @default(uuid())
  emailLogId        String   @map("email_log_id")
  trackingId        String   @map("tracking_id")
  userAgent         String?  @map("user_agent")
  ipAddress         String?  @map("ip_address")
  /// Set true if this hit landed within the prefetch window (likely Gmail
  /// proxy pre-fetching on delivery, not a real open).
  suspectedPrefetch Boolean  @default(false) @map("suspected_prefetch")
  hitAt             DateTime @default(now()) @map("hit_at")

  @@index([emailLogId, hitAt])
  @@index([trackingId])
  @@map("email_pixel_hits")
}

/// Inbound replies fetched from Gmail by polling the thread of a sent email.
/// The first time we see a new message in a thread we own, we insert a row
/// here and bump email_logs.repliedAt.
model EmailReply {
  id         String @id @default(uuid())
  emailLogId String @map("email_log_id")
  leadId     String @map("lead_id")

  gmailMessageId String  @unique @map("gmail_message_id")
  threadId       String  @map("thread_id")
  fromEmail      String  @map("from_email")
  fromName       String? @map("from_name")
  toEmail        String? @map("to_email")
  subject        String?
  snippet        String? @db.Text // short preview from Gmail
  bodyText       String? @map("body_text") @db.Text
  bodyHtml       String? @map("body_html") @db.Text

  receivedAt DateTime @map("received_at")
  createdAt  DateTime @default(now()) @map("created_at")

  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([emailLogId])
  @@index([leadId])
  @@map("email_replies")
}

// ─── Phase 9: Email templates + campaigns ────────────────────────────────

enum CampaignStatus {
  draft
  queued
  running
  paused
  completed
  failed
  cancelled
}

enum CampaignRecipientStatus {
  pending
  sending
  sent
  failed
  skipped
  bounced
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  subject     String
  bodyText    String   @map("body_text") @db.Text
  /// Optional. If null we render bodyText as HTML at send time.
  bodyHtml    String?  @map("body_html") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaigns     Campaign[]
  sequenceSteps SequenceStep[]

  @@index([createdAt])
  @@map("email_templates")
}

model Campaign {
  id          String         @id @default(uuid())
  name        String
  description String?
  status      CampaignStatus @default(draft)

  groupId    String @map("group_id")
  templateId String @map("template_id")
  accountId  String @map("account_id")

  /// Frozen subject + bodies copied from the template at start time.
  /// Editing the template after a campaign starts MUST NOT retroactively
  /// change what recipients see.
  frozenSubject  String? @map("frozen_subject")
  frozenBodyText String? @map("frozen_body_text") @db.Text
  frozenBodyHtml String? @map("frozen_body_html") @db.Text

  /// Per-account daily cap honored at queue-pick time. Default 250
  /// (half of Gmail free-tier 500/day).
  dailySendLimit  Int @default(250) @map("daily_send_limit")
  /// Inter-send delay in seconds. Default 12 (~5/min, gentle on Gmail).
  sendIntervalSec Int @default(12) @map("send_interval_sec")

  recipientCount Int @default(0) @map("recipient_count")
  sentCount      Int @default(0) @map("sent_count")
  failedCount    Int @default(0) @map("failed_count")
  skippedCount   Int @default(0) @map("skipped_count")

  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  group      LeadGroup           @relation(fields: [groupId], references: [id], onDelete: Restrict)
  template   EmailTemplate       @relation(fields: [templateId], references: [id], onDelete: Restrict)
  account    EmailAccount        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  recipients CampaignRecipient[]
  emailLogs  EmailLog[]

  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String  @id @default(uuid())
  campaignId String  @map("campaign_id")
  leadId     String  @map("lead_id")
  contactId  String? @map("contact_id")
  toEmail    String  @map("to_email")

  renderedSubject  String? @map("rendered_subject")
  renderedBodyText String? @map("rendered_body_text") @db.Text
  renderedBodyHtml String? @map("rendered_body_html") @db.Text

  status      CampaignRecipientStatus @default(pending)
  emailLogId  String?                 @unique @map("email_log_id")
  error       String?                 @db.Text
  attemptedAt DateTime?               @map("attempted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  emailLog EmailLog? @relation(fields: [emailLogId], references: [id], onDelete: SetNull)

  @@unique([campaignId, leadId])
  @@index([campaignId, status])
  @@map("campaign_recipients")
}

/// Phase 10 — meetings booked off a lead. Auto-creates a meeting_followup
/// task on completion (idempotent) and promotes the lead to `booked` on
/// schedule (forward-only). When the chosen EmailAccount has the
/// `calendar.events` scope we also create a Google Calendar event and
/// dispatch invites — failures land in `syncError` but never fail the
/// local DB write.
model Meeting {
  id          String        @id @default(uuid())
  leadId      String        @map("lead_id")
  contactId   String?       @map("contact_id")
  /// EmailAccount used to create the GCal event. Null if no calendar sync.
  accountId   String?       @map("account_id")
  title       String
  type        MeetingType   @default(phone)
  /// Optional URL for zoom/meet/etc. Free-form for in_person ("Office, 2nd floor").
  meetingLink String?       @map("meeting_link")
  scheduledAt DateTime      @map("scheduled_at")
  /// Duration in minutes. Default 30. Server stores; UI offers presets.
  durationMin Int           @default(30) @map("duration_min")
  status      MeetingStatus @default(scheduled)
  notes       String?       @db.Text
  /// Free-form follow-up intention captured at meeting completion ("Send proposal", "Loop in finance").
  nextAction  String?       @map("next_action")
  /// Free-form attribution string until multi-tenant arrives. Phase 7+ swaps for a user FK.
  assignedTo  String?       @map("assigned_to")

  /// Email addresses of intended attendees. Defaults to primary contact
  /// email or lead.email at create time. Pass-through to GCal.
  attendeeEmails String[] @default([]) @map("attendee_emails")

  /// Google Calendar sync state. externalEventId is the GCal event id;
  /// externalLink is the htmlLink GCal returns; lastSyncedAt + syncError
  /// expose the most recent attempt to the UI.
  externalProvider String?   @map("external_provider")
  externalEventId  String?   @map("external_event_id")
  externalLink     String?   @map("external_link")
  lastSyncedAt     DateTime? @map("last_synced_at")
  syncError        String?   @map("sync_error") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead    Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  account EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status, scheduledAt])
  @@index([scheduledAt])
  @@index([externalEventId])
  @@map("meetings")
}

/// Phase 11 — proposals. One row per proposal email sent to a lead.
/// On send, links to the EmailLog so the chat drawer thread surfaces the
/// outbound message naturally; deleting the proposal does NOT delete the
/// EmailLog (audit trail stays).
model Proposal {
  id          String         @id @default(uuid())
  leadId      String         @map("lead_id")
  contactId   String?        @map("contact_id")
  accountId   String?        @map("account_id")
  /// Email subject line.
  subject     String
  /// Email body (text). HTML is rendered server-side from the text at send
  /// time using the same plainToHtml helper EmailService uses.
  message     String         @db.Text
  /// Recipient email at the moment of send (snapshotted — primary contact's
  /// email or lead.email at that time).
  toEmail     String         @map("to_email")
  /// Files attached to the proposal email. Same JSON shape as
  /// email_logs.attachments — [{filename,mimeType,size,storagePath}, ...]
  attachments Json           @default("[]")
  status      ProposalStatus @default(draft)
  /// Linked outbound EmailLog when status='sent'. Unique back-relation.
  emailLogId  String?        @unique @map("email_log_id")
  error       String?        @db.Text
  sentAt      DateTime?      @map("sent_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  lead     Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  account  EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  emailLog EmailLog?     @relation("ProposalEmailLog", fields: [emailLogId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status])
  @@map("proposals")
}

/// Phase 12 — manual call logs. No VOIP this phase; the user logs each
/// call after the fact (or schedules one for the future). Status
/// completed → drives stage automation; scheduled → defers it until the
/// user marks completed.
model Call {
  id            String        @id @default(uuid())
  leadId        String        @map("lead_id")
  contactId     String?       @map("contact_id")
  /// Free-form attribution until multi-tenant arrives.
  assignedTo    String?       @map("assigned_to")
  direction     CallDirection
  /// Outbound: toPhone is the lead. Inbound: fromPhone is the lead.
  toPhone       String?       @map("to_phone")
  fromPhone     String?       @map("from_phone")
  /// When the call happened (status='completed') OR is scheduled for
  /// (status='scheduled'). Same column drives both buckets.
  occurredAt    DateTime      @map("occurred_at")
  durationSec   Int?          @map("duration_sec")
  outcome       CallOutcome?
  status        CallStatus    @default(completed)
  notes         String?       @db.Text
  voicemailLeft Boolean       @default(false) @map("voicemail_left")
  /// Captured action item from the call ("send proposal", "schedule demo").
  nextAction    String?       @map("next_action")
  /// Soft-delete: non-null = in trash. Hard delete only on explicit purge.
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([occurredAt])
  @@index([direction, status])
  @@index([deletedAt])
  @@map("calls")
}

// ─── Phase 16: Notifications ──────────────────────────────────────────────

enum NotificationKind {
  email_replied
  campaign_completed
  lead_converted
  lead_lost
  lead_not_converted
}

enum NotificationStatus {
  unread
  read
  dismissed
}

/// Phase 16 — display-layer notifications. We intentionally use a loose
/// (entityType, entityId) pair instead of polymorphic FKs — the entity
/// already enforces its own constraints, and a notification surviving
/// past its target is just stale UI, not corrupt state.
model Notification {
  id         String             @id @default(uuid())
  kind       NotificationKind
  status     NotificationStatus @default(unread)
  title      String
  message    String?            @db.Text
  entityType String?            @map("entity_type")
  entityId   String?            @map("entity_id")
  /// Free-form attribution until multi-tenant arrives. null = workspace-wide.
  assignedTo String?            @map("assigned_to")
  createdAt  DateTime           @default(now()) @map("created_at")
  readAt     DateTime?          @map("read_at")

  @@index([status, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

// ─── Phase 18: Sequences ──────────────────────────────────────────────────

enum SequenceStatus {
  draft
  active
  paused
  archived
}

enum EnrollmentStatus {
  active
  completed
  exited_replied
  exited_stage
  exited_manual
}

/// Multi-step drip sequence. Composed of ordered SequenceSteps that fire
/// against an EmailAccount with per-account daily throttling. Enrollments
/// are 1:1 with leads.
model Sequence {
  id              String         @id @default(uuid())
  name            String
  description     String?
  status          SequenceStatus @default(draft)
  /// Optional group whose leads are auto-enrolled at start. Manual
  /// enrollment is always available regardless of group.
  groupId         String?        @map("group_id")
  accountId       String         @map("account_id")
  dailySendLimit  Int            @default(250) @map("daily_send_limit")
  sendIntervalSec Int            @default(12) @map("send_interval_sec")

  enrolledCount  Int @default(0) @map("enrolled_count")
  completedCount Int @default(0) @map("completed_count")
  exitedCount    Int @default(0) @map("exited_count")

  startedAt  DateTime? @map("started_at")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  group       LeadGroup?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  account     EmailAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([status])
  @@index([createdAt])
  @@map("sequences")
}

model SequenceStep {
  id                     String   @id @default(uuid())
  sequenceId             String   @map("sequence_id")
  /// 0-indexed. Step 0 fires immediately on enrollment (delayDays ignored).
  order                  Int
  /// Wait this many days after the previous step. Ignored for step 0.
  delayDays              Int      @default(0) @map("delay_days")
  templateId             String   @map("template_id")
  stopOnReply            Boolean  @default(true) @map("stop_on_reply")
  stopOnStageProgression Boolean  @default(true) @map("stop_on_stage_progression")
  createdAt              DateTime @default(now()) @map("created_at")

  sequence Sequence      @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([sequenceId, order])
  @@map("sequence_steps")
}

model SequenceEnrollment {
  id            String           @id @default(uuid())
  sequenceId    String           @map("sequence_id")
  leadId        String           @map("lead_id")
  contactId     String?          @map("contact_id")
  /// Resolved at enrollment: primary contact email > lead.email.
  toEmail       String           @map("to_email")
  status        EnrollmentStatus @default(active)
  /// Index of the next step to fire. -1 when terminal.
  nextStepOrder Int              @default(0) @map("next_step_order")
  /// Earliest time the next step can fire. Updated after each send to
  /// (sentAt + nextStep.delayDays * 24h).
  nextSendAt    DateTime         @map("next_send_at")
  enrolledAt    DateTime         @default(now()) @map("enrolled_at")
  exitedAt      DateTime?        @map("exited_at")
  exitReason    String?          @map("exit_reason") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  sequence Sequence                 @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead     Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact  Contact?                 @relation(fields: [contactId], references: [id], onDelete: SetNull)
  sends    SequenceEnrollmentSend[]

  @@unique([sequenceId, leadId])
  @@index([status, nextSendAt])
  @@map("sequence_enrollments")
}

model SequenceEnrollmentSend {
  id               String   @id @default(uuid())
  enrollmentId     String   @map("enrollment_id")
  stepOrder        Int      @map("step_order")
  /// Frozen renders so template edits don't retroactively rewrite history.
  renderedSubject  String   @map("rendered_subject")
  renderedBodyText String   @map("rendered_body_text") @db.Text
  renderedBodyHtml String?  @map("rendered_body_html") @db.Text
  emailLogId       String?  @unique @map("email_log_id")
  sentAt           DateTime @default(now()) @map("sent_at")

  enrollment SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  emailLog   EmailLog?          @relation("SequenceEnrollmentSendEmailLog", fields: [emailLogId], references: [id], onDelete: SetNull)

  @@unique([enrollmentId, stepOrder])
  @@index([sentAt])
  @@map("sequence_enrollment_sends")
}

// ─── Phase 19: Lead stage history ─────────────────────────────────────────
//
// Append-only log of every stage transition. Lets the lead-detail
// activity timeline render "moved from approached → engaged via
// email_replied at HH:MM" entries. We don't backfill historical
// transitions before this phase — they're unrecoverable.

model LeadStageHistory {
  id         String    @id @default(uuid())
  leadId     String    @map("lead_id")
  fromStage  LeadStage @map("from_stage")
  toStage    LeadStage @map("to_stage")
  /// 'manual' for user-driven UI changes; otherwise the existing Trigger
  /// union from StageAutomationService (email_sent, email_opened, etc.).
  trigger    String
  /// Free-form attribution string until multi-tenant arrives.
  actorLabel String?   @map("actor_label")
  occurredAt DateTime  @default(now()) @map("occurred_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, occurredAt])
  @@index([occurredAt])
  @@map("lead_stage_history")
}

// ─── Platform Core: Users, Workspaces, Members, Roles ────────────────────
// Phase 1A foundation. Tenant-scoping of CRM tables comes in Phase 1B.

enum WorkspaceStatus {
  active
  suspended
  expired
}

enum MemberStatus {
  active
  invited
  suspended
}

/// Global identity. One user may belong to many workspaces.
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  name            String
  avatarUrl       String?   @map("avatar_url")
  /// Platform owner (us) — sees the Admin Panel across all workspaces.
  isPlatformAdmin Boolean   @default(false) @map("is_platform_admin")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships     WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")

  @@map("users")
}

/// One workspace per customer. All CRM data scopes to this in Phase 1B.
model Workspace {
  id           String          @id @default(uuid())
  /// URL-friendly identifier (e.g. acme-corp). Used for subdomain routing later.
  slug         String          @unique
  name         String
  status       WorkspaceStatus @default(active)
  /// Max users this workspace may invite. Enforced server-side.
  seatLimit    Int             @default(5) @map("seat_limit")
  ownerId      String?         @map("owner_id")
  /// Optional per-workspace branding.
  logoUrl      String?         @map("logo_url")
  primaryColor String?         @map("primary_color")
  timezone     String          @default("Asia/Dhaka")
  currency     String          @default("BDT")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  owner   User?             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members WorkspaceMember[]
  roles   Role[]

  @@map("workspaces")
}

/// Workspace-scoped role. Permissions stored as an array of strings like "crm.lead.write".
model Role {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  /// Stable identifier: "owner" | "admin" | "manager" | "sales" | "viewer" | custom.
  key         String
  name        String
  description String?
  /// Permission strings. Wildcards allowed: "crm.lead.*" or "*".
  permissions String[]
  /// Seeded defaults can't be deleted, only edited.
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("roles")
}

/// User ↔ Workspace ↔ Role join. This is the "employee record" inside a workspace.
model WorkspaceMember {
  id          String       @id @default(uuid())
  workspaceId String       @map("workspace_id")
  userId      String       @map("user_id")
  roleId      String       @map("role_id")
  status      MemberStatus @default(active)
  /// Optional display title shown in the UI ("Sales Rep", "Manager — North").
  jobTitle    String?      @map("job_title")
  invitedById String?      @map("invited_by_id")
  invitedAt   DateTime?    @map("invited_at")
  joinedAt    DateTime?    @map("joined_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id])

  assignedTasks Task[] @relation("TaskAssignee")
  createdTasks  Task[] @relation("TaskCreatedBy")

  @@unique([workspaceId, userId])
  @@index([workspaceId, status])
  @@index([userId])
  @@map("workspace_members")
}
