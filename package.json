{
  "name": "onspace-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @onspace/db prisma:generate",
    "db:migrate": "pnpm --filter @onspace/db prisma:migrate",
    "db:seed": "pnpm --filter @onspace/db prisma:seed",
    "db:studio": "pnpm --filter @onspace/db prisma:studio",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
