# Postgres
DATABASE_URL="postgresql://onspace:onspace@localhost:5432/onspace_crm?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# API
API_PORT=4000

# ─── Cross-origin / public URLs ──────────────────────────────────────────
# FRONTEND_URL is used for CORS allow-list and as the OAuth-success redirect
# base. Comma-separate to allow multiple origins (e.g. www + apex).
# Example prod value: "https://app.onspace.io,https://onspace.io"
FRONTEND_URL="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Scraper
SCRAPER_HEADFUL=false
SCRAPER_PROXY_URL=""

# Optional enrichment
HUNTER_API_KEY=""

# ─── Gmail OAuth (for sending emails from the CRM) ───────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services → Credentials.
# Add http://localhost:4000/api/email/auth/callback to "Authorized redirect URIs".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/api/email/auth/callback"
# Where to send the user back after a successful connect.
# Defaults to ${FRONTEND_URL}/settings if unset — only set this if you need
# a different page (e.g. a deep link).
EMAIL_OAUTH_SUCCESS_REDIRECT=""

# ─── Open-tracking pixel defense ─────────────────────────────────────────
# Hits within this many seconds of send are treated as the sender's own
# Gmail tab rendering (fetches the pixel) rather than a real recipient
# open. 5 s is the empirical sweet spot — tight enough to count thread
# replies (where the proxy often only fetches once, immediately) and
# generous enough to skip the sender's instant-render. Bump up only if
# you see false positives in your environment.
EMAIL_PREFETCH_WINDOW_SECONDS=5

# ─── Open-tracking cluster gate ──────────────────────────────────────────
# A single proxy hit does not flip an email to "opened" — we require a
# second non-suspect hit within this many seconds. This filters out the
# many non-user-driven reasons Gmail's image proxy can fetch a pixel
# (mobile push preview, inbox refresh in another tab/device, IMAP sync,
# classifier scans). Trade-off: a real open whose proxy cached after one
# fetch won't be marked — the reply path still back-stamps openedAt the
# moment a reply lands, so engaged leads are not lost.
EMAIL_OPEN_CLUSTER_WINDOW_SECONDS=30
# 32+ char string used to encrypt refresh tokens at rest. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_TOKEN_ENC_KEY=""

# ─── Open tracking (auto-tunnel) ─────────────────────────────────────────
# Real-time open detection requires a public URL the recipient can reach.
#
# Tunnel resolution order on boot:
#   1) PUBLIC_API_URL  (production — your real https domain)
#   2) NGROK_AUTHTOKEN (free signup at https://dashboard.ngrok.com)
#   3) cloudflared quick tunnel (zero-config — uses *.trycloudflare.com)
#      Auto-spawned if `cloudflared` is on PATH.
#   4) None (localhost — pixel won't reach recipients).
#
# Set TUNNEL_DISABLED=1 to skip auto-tunnel (e.g. CI).
PUBLIC_API_URL=""
NGROK_AUTHTOKEN=""
