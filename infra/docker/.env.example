# OnspaceCRM production stack — copy to ./.env at repo root and fill in.
#
#   cp infra/docker/.env.example .env

# ── Public hostnames (used by web build + email links) ─────────────────
# After Tailscale Funnel is enabled on the host, set both to your
# tailnet URL. Web + API share one URL: web served at /, api at /api
# (Nest already mounts under /api). Get the URL with:
#   tailscale serve status
# It'll look like: https://desktop-u7er3ui.tail-XXXX.ts.net
PUBLIC_WEB_URL=https://desktop-u7er3ui.tail-XXXX.ts.net
PUBLIC_API_URL=https://desktop-u7er3ui.tail-XXXX.ts.net

# ── Database ───────────────────────────────────────────────────────────
POSTGRES_USER=onspace
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=onspace_crm

# ── Secrets ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex

# ── Gmail OAuth (optional; fill once you set up email sending) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/auth/google/callback

# ── Ingress ────────────────────────────────────────────────────────────
# This stack uses Tailscale Funnel running on the Windows host for free
# public ingress — no env var needed. See infra/docker/DEPLOY.md for
# `tailscale serve` + `funnel on` commands.
