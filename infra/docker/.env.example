# OnspaceCRM production stack — copy to ./.env at repo root and fill in.
#
#   cp infra/docker/.env.example .env

# ── Public hostnames (used by web build + email links) ─────────────────
# After Cloudflare Tunnel routes are configured, set these to the
# hostnames you mapped in the CF dashboard.
PUBLIC_WEB_URL=https://crm.example.com
PUBLIC_API_URL=https://api.example.com

# ── Database ───────────────────────────────────────────────────────────
POSTGRES_USER=onspace
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=onspace_crm

# ── Secrets ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex

# ── Gmail OAuth (optional; fill once you set up email sending) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/auth/google/callback

# ── Cloudflare Tunnel ──────────────────────────────────────────────────
# Get from: https://one.dash.cloudflare.com/  →  Networks → Tunnels →
# create / select tunnel → "Install connector" → Docker tab → copy the
# `--token <...>` value below.
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...
